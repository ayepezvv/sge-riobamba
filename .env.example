# ==========================================
# CONFIGURACIÓN DE INFRAESTRUCTURA SGE
# ==========================================

# --- BASE DE DATOS (DOCKER POSTGRESQL + POSTGIS) ---
# Puerto expuesto en el servidor local (5433 por defecto para no chocar con instalaciones locales)
DB_PORT=5433
DB_NAME=sge_db
DB_USER=sge_admin
DB_PASSWORD=<TU_PASSWORD_AQUI>

# --- BACKEND (FASTAPI) ---
# URL interna para SQLAlchemy
SQLALCHEMY_DATABASE_URL=postgresql+psycopg2://${DB_USER}:${DB_PASSWORD}@localhost:${DB_PORT}/${DB_NAME}
SECRET_KEY=<JWT_SECRET_KEY_AQUI>

# --- FRONTEND (NEXT.JS) ---
# IP del servidor donde corre el backend
NEXT_PUBLIC_API_URL=http://<IP_DEL_SERVIDOR>:8000
