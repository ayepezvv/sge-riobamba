# Variables de entorno requeridas para el backend SGE
# Copiar como .env y completar con valores reales (nunca commitear .env)

# OBLIGATORIO: Clave secreta para firma de JWT. Sin valor → el backend no arranca.
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SGE_SECRET_KEY=

# Base de datos PostgreSQL (Docker en puerto 5433)
DATABASE_URL=postgresql://sge_user:password@localhost:5433/sge_db
